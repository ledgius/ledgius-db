  </coa>
  <currencies default="AUD">
    <currency code="AUD">
      AUD
    </currency>
    <currency code="USD">
      USD
    </currency>
    <currency code="NZD">
      NZD
    </currency>
    <currency code="GBP">
      GBP
    </currency>
    <currency code="EUR">
      EUR
    </currency>
  </currencies>
  <settings>
    <setting name="inventory_accno_id" accno="1510"/>
    <setting name="income_accno_id" accno="4010"/>
    <setting name="expense_accno_id" accno="5010"/>
    <setting name="fxgain_accno_id" accno="4450"/>
    <setting name="fxloss_accno_id" accno="6300"/>
    <setting name="weightunit" value="kg"/>
  </settings>
</configuration>
