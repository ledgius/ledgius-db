      <account code="6240" description="Security" category="Expense">
        <link code="AP_amount"/>
      </account>
      <account code="6250" description="Software &amp; Subscriptions" category="Expense">
        <link code="AP_amount"/>
      </account>
      <account code="6260" description="Telephone &amp; Internet" category="Expense">
        <link code="AP_amount"/>
      </account>
      <account code="6270" description="Travel - Domestic" category="Expense"/>
